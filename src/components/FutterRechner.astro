---
// Futterrechner Komponente
---

<div class="bg-straw/30 rounded-2xl p-6 max-w-2xl">
  <h3 class="font-display text-2xl font-bold text-bark mb-4">🌾 Futterrechner</h3>
  <div class="space-y-4">
    <div>
      <label class="block text-sm font-semibold text-bark mb-2">Anzahl Hühner:</label>
      <input type="number" id="futter-count" value="8" min="1" class="w-full p-2 border border-straw-dark/30 rounded" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-bark mb-2">Tage:</label>
      <input type="number" id="futter-tage" value="30" min="1" class="w-full p-2 border border-straw-dark/30 rounded" />
    </div>
  </div>
  <div id="futter-result" class="mt-6 p-4 bg-white rounded-lg border border-straw-dark/30 text-sm text-earth"></div>
</div>

<script>
  const calculateFutter = () => {
    const count = parseInt(document.getElementById('futter-count').value) || 0;
    const tage = parseInt(document.getElementById('futter-tage').value) || 0;
    const tagesverbrauch = count * 0.12; // kg pro Huhn pro Tag
    const gesamt = (tagesverbrauch * tage).toFixed(1);
    document.getElementById('futter-result').innerHTML = `
      <strong>Futterverbrauch für ${count} Hühner über ${tage} Tage:</strong><br>
      ${gesamt} kg Futter nötig
    `;
  };
  document.getElementById('futter-count')?.addEventListener('input', calculateFutter);
  document.getElementById('futter-tage')?.addEventListener('input', calculateFutter);
  calculateFutter();
</script>