---
import Base from '../../layouts/Base.astro';

const articles = [
  { title: 'Kunstbrut: Die komplette Anleitung', href: '/brut/kunstbrut-anleitung/', desc: 'Temperatur, Luftfeuchtigkeit, Wenden – Schritt für Schritt erklärt.' },
  { title: 'Naturbrut mit Glucke: So gelingt es', href: '/brut/naturbrut-glucke/', desc: 'Wie du eine Glucke erkennst, einsetzt und unterstützt.' },
];
---

<Base title="Brut & Küken" description="Kunstbrut, Naturbrut und Kükenaufzucht – Schritt für Schritt Anleitungen.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <header class="mb-10 max-w-2xl">
      <span class="inline-block bg-forest/10 text-forest text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">Brut & Küken</span>
      <h1 class="font-display text-4xl font-bold text-bark mb-4">Brut & Küken 🥚</h1>
      <p class="text-earth text-lg leading-relaxed">Von der Bruteikontrolle bis zum flauschigen Küken: Hier findest du alle Anleitungen zur erfolgreichen Kunstbrut und Naturbrut.</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {articles.map(a => (
        <a href={a.href} class="group bg-white border border-straw-dark/30 rounded-xl p-6 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <div class="text-2xl mb-3">🥚</div>
          <h2 class="font-display font-bold text-bark group-hover:text-forest transition-colors mb-2">{a.title}</h2>
          <p class="text-sm text-earth leading-relaxed">{a.desc}</p>
          <div class="mt-4 text-xs font-semibold text-forest/70 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Lesen →</div>
        </a>
      ))}
    </div>
  </div>
</Base>